# Placer Hub — Environment Variables
# Copy to .env.local and fill in values
# Never commit .env.local to Git

# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Site
# ============================================================
NEXT_PUBLIC_SITE_URL=https://hub.placerrobotics.org
# Local: http://localhost:3000

# Feature flags (default OFF unless set to 'true'):
# NEXT_PUBLIC_FEATURE_FINANCIAL_AID — show the family-facing financial-aid feature
# (dashboard row, /financial-aid page, /apply callout). Admin views are never gated.
# NEXT_PUBLIC_FEATURE_FINANCIAL_AID=false

# ============================================================
# Bootstrap
# ============================================================
# Email address granted Super Admin on first schema migration
BOOTSTRAP_ADMIN_EMAIL=kevin.miller@placerrobotics.org

# ============================================================
# Transactional email (Resend | SendGrid | Postmark)
# ============================================================
# RESEND_API_KEY=
# EMAIL_FROM=noreply@placerrobotics.org

# ============================================================
# Zeffy
# ============================================================
# ZEFFY_API_KEY=
# ZEFFY_WEBHOOK_SECRET=
# ZEFFY_STUDENT_CAMPAIGN_ID=
# ZEFFY_IQ_TEAM_CAMPAIGN_ID=

# ============================================================
# Google Admin SDK (for Google Group sync — Release 4)
# ============================================================
# GOOGLE_ADMIN_EMAIL=admin@placerrobotics.org
# GOOGLE_SERVICE_ACCOUNT_KEY=  (JSON, base64 encoded)

# ============================================================
# Slack (Release 3+)
# ============================================================
# SLACK_MAIN_BOT_TOKEN=
# SLACK_IQ_BOT_TOKEN=

# ============================================================
# APS / MinistrySafe (Release 3)
# ============================================================
# APS_API_KEY=
# APS_API_BASE_URL=

# ============================================================
# UniFi Access (Release 3)
# ============================================================
# UNIFI_ACCESS_API_KEY=
# UNIFI_ACCESS_BASE_URL=

# ============================================================
# Google Sheets (Phase 1 sync job + ETL scripts)
# ============================================================
# GOOGLE_SHEETS_API_KEY=
# REGISTRATION_SHEET_ID=
# VOLUNTEER_SHEET_ID=1ihw4Z0RLwQn6I1T49XSf2FeS1HsMo4oPN1L_qPClSPo
